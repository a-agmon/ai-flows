# Copy to `.env`. Only OPENAI_API_KEY is required (for `llm` nodes).

# --- Secrets (no AI_FLOWS_ prefix; read by the OpenAI client) ---------------
OPENAI_API_KEY=sk-...

# --- App settings (AI_FLOWS_ prefix; read by app.settings.Settings) ---------
# Logging.
# AI_FLOWS_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
# AI_FLOWS_LOG_FORMAT=console        # console (dev) | json (prod)

# Flow sources (defaults shown).
# AI_FLOWS_CONFIGS_DIR=./configs
# AI_FLOWS_PROMPTS_DIR=./app/prompts
# AI_FLOWS_MODULES_PACKAGE=app.modules
